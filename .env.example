# Dako Studios Bootcamp environment template
# Copy to `.env` and fill in real values locally.

# Core app
SQLITE_PATH=data/bootcamp.db
BASE_URL=http://localhost:8000
BOOTCAMP_PRICE_USD=49
ASYNC_GRADING=true

# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_ROUTER_URL=https://YOUR-DOMAIN/webhook
ALLOW_PAYMENT_DEV_BYPASS=false

# Gemini AI feedback
# Google recommends GOOGLE_API_KEY taking precedence if both are set.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

# Optional runtime services
DATABASE_URL=
REDIS_URL=
BLOB_READ_WRITE_TOKEN=
